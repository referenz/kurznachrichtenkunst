{
  "tasks": {
    "chatgpt-test": "deno run -P ./src/test/chatGPT.ts",
    "gemini-test": "deno run -P ./src/test/gemini.ts",
    "ai-test": {
      "dependencies": [
        "chatgpt-test",
        "gemini-test"
      ]
    },
    "run": "deno run -P --env-file=.env ./src/main.ts"
  },
  "imports": {
    "@atproto/api": "npm:@atproto/api@^0.19.3",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.78.0",
"@google/generative-ai": "npm:@google/generative-ai@^0.24.1",
    "openai": "npm:openai@^6.4.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.2.0",
    "rss-parser": "npm:rss-parser@^3.13.0",
    "zod": "npm:zod@^4.3.6"
  },
  "permissions": 		{
			"default": {
				"env": true,
				"net": true,
				"read": true
			}
		},
  "fmt": {
    "lineWidth": 120
  }
}
